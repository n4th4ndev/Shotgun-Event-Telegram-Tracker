TELEGRAM_BOT_TOKEN=your_telegram_bot_token
SHOTGUN_TOKEN=your_shotgun_organizer_token
SHOTGUN_ORGANIZER_ID=your_shotgun_organizer_id
# Optional: comma-separated Telegram chat IDs allowed to use the bot. Empty = everyone.
BOTSHOTGUN_ALLOWED_CHAT_IDS=
# Optional: marker identifying a co-organized event's host (default: palmeraie).
# The daily morning check flags every upcoming event whose host does NOT contain it.
SHOTGUN_COORG_MARKER=palmeraie
